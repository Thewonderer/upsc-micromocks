# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# sqlite database (seed.db is committed for deployment)
/data/cache.db
/data/cache.db-wal
/data/cache.db-shm

# processed questions (keep inbox for git tracking)
/questions-inbox/processed/*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
